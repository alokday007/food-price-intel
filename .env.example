# Food Price Intelligence — environment variables.
# Copy to .env and fill in real values. NEVER commit .env.

# --- Django core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL (consumed by both Django and the db service) ---
POSTGRES_DB=foodpriceintel
POSTGRES_USER=foodpriceintel
POSTGRES_PASSWORD=change-me
# Use "db" (the compose service name) when running under docker-compose;
# use "localhost" when running Django directly against a local Postgres.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis cache ---
# Use the "redis" service name under docker-compose; "localhost" otherwise.
REDIS_URL=redis://redis:6379/0
